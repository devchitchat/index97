<template data-slot="title">Edit: {{post.title}} — index97</template>

<h1>Edit Post</h1>

<form method="PUT" action="/blog/{{post.slug}}/edit">
  <div>
    <label for="title">Title</label>
    <input type="text" id="title" name="title" value="{{post.title}}" required autofocus>
  </div>
  <div>
    <label for="body">Body <small>(Markdown)</small></label>
    <textarea id="body" name="body" rows="20">{{post.body}}</textarea>
  </div>
  <div>
    <button type="submit">Save</button>
    <a href="/blog/{{post.slug}}">Cancel</a>
  </div>
</form>
