<template data-slot="title">New Post — index97</template>

<h1>New Post</h1>

<form method="POST" action="/blog/new">
  <div>
    <label for="title">Title</label>
    <input type="text" id="title" name="title" required autofocus placeholder="Post title">
  </div>
  <div>
    <label for="body">Body <small>(Markdown)</small></label>
    <textarea id="body" name="body" rows="20" placeholder="Write your post in Markdown..."></textarea>
  </div>
  <div>
    <button type="submit">Publish</button>
    <a href="/blog">Cancel</a>
  </div>
</form>
